{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@opencode-ai/clangd-mcp",
  "version": "0.2.0",
  "description": "Standalone MCP server bridging clangd LSP to OpenCode agents",
  "type": "module",
  "license": "MIT",
  "private": true,
  "bin": {
    "clangd-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "/usr2/adagur/.bun/bin/bun build ./src/index.ts --outfile ./dist/index.js --target node --format esm && /usr2/adagur/.bun/bin/bun build ./src/bridge/index.ts --outfile ./dist/bridge.js --target node --format esm",
    "dev": "/usr2/adagur/.bun/bin/bun run ./src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit/",
    "test:integration": "vitest run test/integration/",
    "test:e2e": "vitest run test/e2e/",
    "test:watch": "vitest",
    "test:legacy": "node test-clangd-mcp.mjs",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.2",
    "vscode-jsonrpc": "8.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
